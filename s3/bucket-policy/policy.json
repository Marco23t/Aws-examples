{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListBucket",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::021502749434:user/codespace-user"
      },
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::bucket-policy-example-mt-21212121"
    },
    {
      "Sid": "AllowObjectAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::021502749434:user/codespace-user"
      },
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::bucket-policy-example-mt-21212121/*"
    }
  ]
}